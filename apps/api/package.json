  "devDependencies": {
    "@nestjs/cli": "11.0.10",
    "@nestjs/testing": "11.1.19",
    "@types/node": "22.19.17",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "17.4.2",
    "eslint": "9.18.0",
