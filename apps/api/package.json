{
  "name": "@mall/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
