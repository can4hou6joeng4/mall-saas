# Database
# DATABASE_URL：超管账号，用于跑 prisma migrate deploy / 平台元数据
DATABASE_URL=postgresql://mall:mall@localhost:5432/mall?schema=public
# DATABASE_APP_URL：mall_app 非超管角色，应用运行时连接（受 RLS 约束）
DATABASE_APP_URL=postgresql://mall_app:mall_app@localhost:5432/mall?schema=public

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
# JWT_SECRET：JWT 签名密钥，至少 32 字符（生产环境务必改成随机长串）
JWT_SECRET=please-change-me-to-a-very-long-random-string-of-at-least-32-chars
JWT_TTL_SECONDS=3600

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
