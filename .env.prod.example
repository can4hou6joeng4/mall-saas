# ============================================================================
# Mall 生产 env 模板。把这个文件复制成 .env.prod 后填入真实值；不要入库。
# 所有 ?required 字段必须显式提供，否则 compose 启动失败。
# ============================================================================

# ----- 镜像（CI/CD 推送后填实际 tag，例如 ghcr.io/<owner>/mall-api:v0.25.0-m25）
MALL_API_IMAGE=mall-api:latest

# ----- Postgres 超管（用于 prisma migrate / 平台元数据）
POSTGRES_USER=mall
POSTGRES_PASSWORD=    # ← 必填，强随机
POSTGRES_DB=mall

# ----- Postgres app 角色（受 RLS 约束，应用运行时连接）
# 注意：app 用户与权限需要在初次部署时手动创建，参考 docs/deploy.md
POSTGRES_APP_USER=mall_app
POSTGRES_APP_PASSWORD=    # ← 必填，强随机

# ----- JWT
# 至少 32 字符；推荐 openssl rand -base64 48
JWT_SECRET=    # ← 必填
JWT_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# ----- Payment（mock 模式；接入真实 provider 时把 PAYMENT_DEFAULT_PROVIDER 设为 stripe 并加 STRIPE_*）
PAYMENT_MOCK_SECRET=    # ← 必填，至少 16 字符

# ----- 平台管理员（首次启动时由 admin-auth bootstrap 自动注入）
PLATFORM_ADMIN_EMAIL=    # ← 必填
PLATFORM_ADMIN_PASSWORD=    # ← 必填，强随机

# ----- 限流（生产建议 AUTH_RATE_LIMIT_MAX=30，公网入口尤其敏感）
AUTH_RATE_LIMIT_MAX=30
RATE_LIMIT_MAX=200

# ----- 订单超时（毫秒）
ORDER_TIMEOUT_MS=1800000

# ----- 日志
LOG_LEVEL=info

# ----- API 暴露端口（前面通常挂 Caddy/Nginx + TLS）
API_PORT=3000
